{
    "name": "pdf-toolbox",
    "version": "1.0.0",
    "private": true,
    "description": "纯前端本地 PDF 工具箱",
    "scripts": {
        "lint": "npm run lint:js && npm run lint:inline",
        "lint:all": "npm run lint && npm run format:check",
        "lint:js": "eslint \"js/**/*.js\" \"scripts/**/*.cjs\"",
        "lint:inline": "node scripts/lint-inline-scripts.cjs",
        "format": "prettier --write \"*.html\" \"css/**/*.css\" \"js/**/*.js\" \"README.md\"",
        "format:check": "prettier --check \"*.html\" \"css/**/*.css\" \"js/**/*.js\" \"README.md\""
    },
    "devDependencies": {
        "eslint": "^9.26.0",
        "globals": "^15.15.0",
        "prettier": "^3.3.3"
    }
}
